# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real credentials.

# From Supabase dashboard → Settings → API
SUPABASE_URL=https://trvhrdrrhejntqzbwmpz.supabase.co

# Service role key (secret). Server-side only. DO NOT expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Private bucket that holds course materials. Will be created if missing.
SUPABASE_COURSE_BUCKET=course-materials

# Gmail SMTP for sending course emails
# Generate an App Password at https://myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=
EMAIL_FROM=Juris <your@gmail.com>
